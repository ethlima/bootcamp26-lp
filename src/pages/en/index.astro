---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Hero from "@/components/Hero.astro";
import Intro from "@/components/Intro.astro";
import Marquee from "@/components/Marquee.astro";
import HowItWorks from "@/components/HowItWorks.astro";
import Audience from "@/components/Audience.astro";
import Curriculum from "@/components/Curriculum.astro";
import Outcomes from "@/components/Outcomes.astro";
import Ecosystem from "@/components/Ecosystem.astro";
import Process from "@/components/Process.astro";
import FAQ from "@/components/FAQ.astro";
import FinalCTA from "@/components/FinalCTA.astro";
import Footer from "@/components/Footer.astro";
import { getContent } from "@/i18n";

const t = getContent("en");

const courseSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  name: t.site.name,
  description: t.site.description,
  url: `${t.site.url}/en/`,
  image: `${t.site.url}/assets/llama-bootcamp.jpg`,
  inLanguage: "en",
  educationalLevel: "Beginner",
  teaches: ["Solidity", "Rust", "Arbitrum Stylus", "Smart Contracts", "Web3", "dApps", "Blockchain", "Ethereum"],
  coursePrerequisites: "Basic programming knowledge",
  provider: {
    "@type": "Organization",
    name: t.ecosystem.parent.name,
    url: t.ecosystem.parent.url,
    sameAs: [
      t.ecosystem.parent.url,
      "https://x.com/ethereumlima",
      "https://t.me/ethlima",
      "https://www.linkedin.com/company/ethereum-lima",
    ],
  },
  about: [
    "Ethereum",
    "Solidity",
    "Rust",
    "Arbitrum Stylus",
    "Smart Contracts",
    "Web3",
    "Blockchain",
    "dApps",
  ],
  hasCourseInstance: {
    "@type": "CourseInstance",
    courseMode: "Online",
    startDate: "2026-05-30",
    endDate: "2026-07-04",
    inLanguage: "en",
    location: {
      "@type": "VirtualLocation",
      url: `${t.site.url}/en/`,
    },
  },
  offers: {
    "@type": "Offer",
    url: t.site.applyUrl,
    price: "0",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
    category: "Free",
  },
};

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Ethereum Lima",
  url: "https://ethlima.org",
  logo: `${t.site.url}/assets/logo.webp`,
  sameAs: [
    "https://ethlima.org",
    "https://x.com/ethereumlima",
    "https://t.me/ethlima",
    "https://www.linkedin.com/company/ethereum-lima",
    "https://www.instagram.com/ethereumlima",
  ],
};
---

<Layout>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(courseSchema)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(orgSchema)} />
  </Fragment>
  <Nav />
  <main>
    <Hero />
    <Intro />
    <Marquee />
    <HowItWorks />
    <Audience />
    <Curriculum />
    <Outcomes />
    <Ecosystem />
    <Process />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</Layout>
