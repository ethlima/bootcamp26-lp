---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Hero from "@/components/Hero.astro";
import Intro from "@/components/Intro.astro";
import Marquee from "@/components/Marquee.astro";
import HowItWorks from "@/components/HowItWorks.astro";
import Audience from "@/components/Audience.astro";
import Curriculum from "@/components/Curriculum.astro";
import Outcomes from "@/components/Outcomes.astro";
import Ecosystem from "@/components/Ecosystem.astro";
import Process from "@/components/Process.astro";
import FAQ from "@/components/FAQ.astro";
import FinalCTA from "@/components/FinalCTA.astro";
import Footer from "@/components/Footer.astro";
import { site, ecosystem } from "@/data/content";

const courseSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  name: site.name,
  description: site.description,
  url: site.url,
  image: `${site.url}/assets/llama-bootcamp.jpg`,
  inLanguage: "es",
  provider: {
    "@type": "Organization",
    name: ecosystem.parent.name,
    url: ecosystem.parent.url,
    sameAs: ecosystem.parent.url,
  },
  about: [
    "Ethereum",
    "Solidity",
    "Rust",
    "Arbitrum Stylus",
    "Smart Contracts",
    "Web3",
    "Blockchain",
    "dApps",
  ],
  hasCourseInstance: {
    "@type": "CourseInstance",
    courseMode: "Online",
    startDate: "2026-05-30",
    endDate: "2026-07-04",
    inLanguage: "es",
    location: {
      "@type": "VirtualLocation",
      url: site.url,
    },
  },
  offers: {
    "@type": "Offer",
    url: site.applyUrl,
    availability: "https://schema.org/InStock",
    category: "Educational",
  },
};
---

<Layout>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(courseSchema)} />
  </Fragment>
  <Nav />
  <main>
    <Hero />
    <Intro />
    <Marquee />
    <HowItWorks />
    <Audience />
    <Curriculum />
    <Outcomes />
    <Ecosystem />
    <Process />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</Layout>
