---
import Button from "./ui/Button.astro";
import { navLinks, site } from "@/data/content";
---

<nav class="fixed top-0 inset-x-0 z-50 backdrop-blur-md bg-[#0b0717cc] border-b border-border">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="#top" class="flex items-center gap-2.5 group">
      <img
        src="/assets/logo.webp"
        alt="Ethereum Lima"
        class="h-8 w-auto group-hover:scale-105 transition-transform"
      />
    </a>

    <div class="hidden md:flex items-center gap-7 text-sm text-fg-muted">
      {
        navLinks.map((link) => (
          <a href={link.href} class="nav-link hover:text-white transition">
            {link.label}
          </a>
        ))
      }
    </div>

    <Button href={site.applyUrl} external size="md">Aplicar</Button>
  </div>
</nav>
