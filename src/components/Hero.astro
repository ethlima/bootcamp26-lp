---
import Button from "./ui/Button.astro";
import Icon from "./ui/Icon.astro";
import { getContent, isLocale, DEFAULT_LOCALE } from "@/i18n";

const lang = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const t = getContent(lang);
---

<section
  id="top"
  class="relative pt-32 md:pt-40 pb-20 md:pb-28 px-6 overflow-hidden glow-hero dotted-bg"
>
  <div class="max-w-6xl mx-auto relative">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-8 items-center">

      <!-- Columna texto -->
      <div class="lg:col-span-7 relative z-10">
        <div class="hero-anim inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-border-strong bg-fg/5 backdrop-blur-sm text-xs md:text-sm text-fg-muted mb-7"
          style="animation-delay: 0ms;">
          <span class="w-2 h-2 rounded-full bg-accent animate-pulse-dot"></span>
          {t.cohort.label} · {t.cohort.applicationsOpen}
        </div>

        <h1 class="hero-anim font-display text-5xl sm:text-6xl lg:text-7xl xl:text-[5.5rem] leading-[1.02] mb-6"
          style="animation-delay: 120ms;">
          {t.hero.headingLine1}<br />
          {t.hero.headingLine2Pre}<span class="gradient-llama">{t.hero.headingLine2Highlight}</span><br />
          {t.hero.headingLine3}
        </h1>

        <p class="hero-anim text-lg md:text-xl text-fg-muted max-w-xl mb-7 leading-relaxed"
          style="animation-delay: 280ms;">
          {t.hero.description}
        </p>

        <div class="hero-anim flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-fg-muted mb-9"
          style="animation-delay: 400ms;">
          <span class="font-semibold text-fg">{t.cohort.weeks} {t.cohort.weeksLabel}</span>
          <span class="opacity-30">·</span>
          <span>{t.cohort.startLabel} — {t.cohort.endLabel}</span>
          <span class="opacity-30">·</span>
          <span>{t.cohort.format}</span>
        </div>

        <div class="hero-anim flex flex-col sm:flex-row gap-3"
          style="animation-delay: 520ms;">
          <Button href={t.site.applyUrl} external variant="primary" size="lg">
            {t.ui.applyNow}
            <Icon name="arrow-right" class="w-4 h-4" strokeWidth={2.5} />
          </Button>
          <Button href={t.site.programPdf} variant="ghost" size="lg" external>
            {t.ui.programPdf}
          </Button>
        </div>
      </div>

      <!-- Columna llama -->
      <div class="lg:col-span-5 relative hero-anim-scale" style="animation-delay: 300ms;">
        <div class="relative animate-float">
          <!-- Glow detrás de la llama -->
          <div class="absolute inset-0 -m-8 rounded-[3rem] blur-3xl opacity-50"
            style="background: radial-gradient(circle, rgba(61, 190, 213, 0.5) 0%, rgba(199, 247, 58, 0.3) 50%, transparent 80%);">
          </div>

          <div class="relative rounded-3xl overflow-hidden border border-border-strong aspect-[3/2] lg:aspect-[5/4] bg-surface">
            <img
              src="/assets/llama-bootcamp.jpg"
              alt={t.hero.llamaAlt}
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>

          <!-- Badge flotante -->
          <div class="absolute -bottom-5 -left-5 lg:-left-8 bg-bootcamp-lime text-ink rounded-2xl px-4 py-3 shadow-2xl rotate-[-3deg] hidden md:block">
            <p class="text-[10px] font-mono uppercase tracking-widest opacity-70">{t.hero.badgeLabel}</p>
            <p class="font-display text-base font-bold">{t.hero.badgeProject}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
