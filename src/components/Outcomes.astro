---
import Section from "./ui/Section.astro";
import { outcomes } from "@/data/content";

const accents = ["#e64a30", "#f18a2e", "#3dbed5", "#2ca89f", "#c7f73a"];
---

<Section>
  <span class="text-xs uppercase tracking-[0.25em] font-mono font-semibold text-bootcamp-lime">
    Resultados
  </span>
  <h2 class="font-display text-3xl md:text-5xl mt-4 mb-12 leading-[1.1]">
    Qué te llevas al terminar.
  </h2>

  <div class="grid sm:grid-cols-2 gap-4 reveal-stagger">
    {
      outcomes.map((outcome, i) => {
        const color = accents[i % accents.length];
        return (
          <div
            class={`card p-6 flex items-start gap-4 ${i === outcomes.length - 1 ? "sm:col-span-2" : ""}`}
          >
            <div
              class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 border"
              style={`background-color: ${color}22; border-color: ${color}66;`}
            >
              <svg
                class="w-5 h-5"
                style={`color: ${color}`}
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <p class="pt-1.5 font-medium">{outcome}</p>
          </div>
        );
      })
    }
  </div>
</Section>
