---
import Section from "./ui/Section.astro";
import Icon from "./ui/Icon.astro";
import Eyebrow from "./ui/Eyebrow.astro";
import { getContent, isLocale, DEFAULT_LOCALE } from "@/i18n";
import { stepColors } from "@/data/tokens";

const lang = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const t = getContent(lang);
const s = t.sections.process;
---

<Section>
  <div class="text-center mb-16">
    <Eyebrow>{s.eyebrow}</Eyebrow>
    <h2 class="font-display text-3xl md:text-5xl mt-4 leading-[1.1]">
      {s.headingPre}<span class="gradient-llama">{s.headingHighlight}</span>{s.headingPost}
    </h2>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 relative reveal-stagger">
    {
      t.process.map((p, i) => {
        const color = stepColors[i];
        return (
          <div class="card p-7 relative group">
            <div
              class="w-14 h-14 rounded-2xl font-display font-bold text-2xl flex items-center justify-center mb-5 transition-transform group-hover:scale-110 group-hover:rotate-[-3deg]"
              style={`background-color: ${color.bg}; color: ${color.text};`}
            >
              {p.step}
            </div>
            <h3 class="font-display text-lg font-bold mb-2">{p.title}</h3>
            <p class="text-sm text-fg-muted leading-relaxed">{p.description}</p>

            {i < t.process.length - 1 && (
              <Icon
                name="chevron-right"
                class="hidden lg:block absolute top-12 -right-3 w-6 h-6 text-border-strong"
              />
            )}
          </div>
        );
      })
    }
  </div>
</Section>
