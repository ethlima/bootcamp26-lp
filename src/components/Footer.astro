---
import { getContent, isLocale, DEFAULT_LOCALE } from "@/i18n";

const lang = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const t = getContent(lang);

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border py-14 px-6 bg-surface-2">
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-3 gap-10 mb-10">

      <!-- Brand -->
      <div>
        <a href="#top" class="flex items-center gap-2 mb-4">
          <img src="/assets/logo.webp" alt="Ethereum Lima" class="h-10 w-auto" />
        </a>
        <p class="text-sm text-fg-muted leading-relaxed">
          {t.footer.tagline}
        </p>
      </div>

      <!-- Ecosistema -->
      <div>
        <p class="text-xs uppercase tracking-widest text-fg-muted font-mono font-semibold mb-4">
          {t.footer.ecosystemLabel}
        </p>
        <ul class="space-y-2.5 text-sm">
          <li><a href={t.ecosystem.parent.url} target="_blank" rel="noopener" class="text-fg-muted hover:text-fg transition">{t.ecosystem.parent.name}</a></li>
          <li><a href={t.ecosystem.education.url} target="_blank" rel="noopener" class="text-fg-muted hover:text-fg transition">{t.ecosystem.education.name}</a></li>
          <li><a href={t.ecosystem.event.url} target="_blank" rel="noopener" class="text-fg-muted hover:text-fg transition">{t.ecosystem.event.name}</a></li>
        </ul>
      </div>

      <!-- Contacto + redes -->
      <div>
        <p class="text-xs uppercase tracking-widest text-fg-muted font-mono font-semibold mb-4">
          {t.footer.contactLabel}
        </p>
        <a href={`mailto:${t.site.contactEmail}`} class="text-sm text-fg-muted hover:text-fg transition block mb-5">
          {t.site.contactEmail}
        </a>
        <div class="flex flex-wrap gap-3">
          <a href={t.social.telegram} target="_blank" rel="noopener" class="text-sm px-3.5 py-1.5 rounded-full border border-border text-fg-muted hover:border-accent hover:text-accent transition">Telegram</a>
          <a href={t.social.x} target="_blank" rel="noopener" class="text-sm px-3.5 py-1.5 rounded-full border border-border text-fg-muted hover:border-fg hover:text-fg transition">X</a>
          <a href={t.social.linkedin} target="_blank" rel="noopener" class="text-sm px-3.5 py-1.5 rounded-full border border-border text-fg-muted hover:border-cyan hover:text-cyan transition">LinkedIn</a>
          <a href={t.social.instagram} target="_blank" rel="noopener" class="text-sm px-3.5 py-1.5 rounded-full border border-border text-fg-muted hover:border-coral hover:text-coral transition">Instagram</a>
        </div>
      </div>
    </div>

    <div class="pt-8 border-t border-border flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div class="flex flex-wrap items-center gap-x-5 gap-y-1">
        <p class="text-xs text-fg-muted">
          © {currentYear} {t.footer.copyrightSuffix}
        </p>
        <a
          href={lang === "en" ? "/en/privacy/" : "/privacidad/"}
          class="text-xs text-fg-muted hover:text-fg transition underline-offset-2 hover:underline"
        >
          {t.footer.privacyLabel}
        </a>
      </div>
      <p class="text-xs text-fg-muted font-mono">
        {t.footer.madeIn} <span class="gradient-llama">♥</span> {t.footer.madeInSuffix}
        <a
          href="https://github.com/javierarteagagonzales"
          target="_blank"
          rel="noopener"
          class="hover:text-fg transition underline-offset-2 hover:underline"
        >Jargo</a>
        <span class="opacity-40"> · </span>
        <a
          href="https://github.com/bogos"
          target="_blank"
          rel="noopener"
          class="hover:text-fg transition underline-offset-2 hover:underline"
        >Bogo</a>
      </p>
    </div>
  </div>
</footer>

<!-- Botón flotante volver arriba -->
<button
  id="back-to-top"
  aria-label="Volver arriba"
  title="Volver arriba"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <polyline points="18 15 12 9 6 15"/>
  </svg>
</button>

<style>
  #back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    background: var(--color-surface-2);
    border: 1px solid var(--color-border-strong);
    color: var(--color-fg-muted);
    cursor: pointer;
    box-shadow: 0 4px 24px rgba(0,0,0,0.18);
    opacity: 0;
    visibility: hidden;
    transform: translateY(12px);
    transition: opacity 0.25s ease, transform 0.25s ease, visibility 0.25s, color 0.15s, border-color 0.15s, background 0.15s;
  }

  #back-to-top.is-visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  #back-to-top:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: var(--color-surface);
  }

  #back-to-top:active {
    transform: translateY(2px);
  }
</style>

<script>
  const btn = document.getElementById('back-to-top');
  if (btn) {
    const toggle = () => {
      if (window.scrollY > 400) {
        btn.classList.add('is-visible');
      } else {
        btn.classList.remove('is-visible');
      }
    };
    window.addEventListener('scroll', toggle, { passive: true });
    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
    toggle();
  }
</script>
