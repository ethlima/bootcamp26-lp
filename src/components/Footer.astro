---
import { site, social, ecosystem } from "@/data/content";

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)] py-14 px-6 bg-[#0e0a1f]">
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-3 gap-10 mb-10">

      <!-- Brand -->
      <div>
        <a href="#top" class="flex items-center gap-2 mb-4">
          <img src="/assets/logo.webp" alt="Ethereum Lima" class="h-8 w-auto" />
        </a>
        <p class="text-sm text-[var(--color-fg-muted)] leading-relaxed">
          Comunidad y educación blockchain en Lima.<br />
          Construyendo el ecosistema Web3 en Perú.
        </p>
      </div>

      <!-- Ecosistema -->
      <div>
        <p class="text-xs uppercase tracking-widest text-[var(--color-fg-muted)] font-mono font-semibold mb-4">
          Ecosistema
        </p>
        <ul class="space-y-2.5 text-sm">
          <li><a href={ecosystem.parent.url} target="_blank" rel="noopener" class="text-[var(--color-fg-muted)] hover:text-white transition">{ecosystem.parent.name}</a></li>
          <li><a href={ecosystem.education.url} target="_blank" rel="noopener" class="text-[var(--color-fg-muted)] hover:text-white transition">{ecosystem.education.name}</a></li>
          <li><a href={ecosystem.event.url} target="_blank" rel="noopener" class="text-[var(--color-fg-muted)] hover:text-white transition">{ecosystem.event.name}</a></li>
        </ul>
      </div>

      <!-- Contacto + redes -->
      <div>
        <p class="text-xs uppercase tracking-widest text-[var(--color-fg-muted)] font-mono font-semibold mb-4">
          Contacto
        </p>
        <a href={`mailto:${site.contactEmail}`} class="text-sm text-[var(--color-fg-muted)] hover:text-white transition block mb-5">
          {site.contactEmail}
        </a>
        <div class="flex flex-wrap gap-3">
          <a href={social.telegram} target="_blank" rel="noopener" class="text-sm px-3.5 py-1.5 rounded-full border border-[var(--color-border)] text-[var(--color-fg-muted)] hover:border-[var(--color-bootcamp-lime)] hover:text-[var(--color-bootcamp-lime)] transition">Telegram</a>
          <a href={social.x} target="_blank" rel="noopener" class="text-sm px-3.5 py-1.5 rounded-full border border-[var(--color-border)] text-[var(--color-fg-muted)] hover:border-white hover:text-white transition">X</a>
          <a href={social.linkedin} target="_blank" rel="noopener" class="text-sm px-3.5 py-1.5 rounded-full border border-[var(--color-border)] text-[var(--color-fg-muted)] hover:border-[var(--color-cyan)] hover:text-[var(--color-cyan)] transition">LinkedIn</a>
          <a href={social.instagram} target="_blank" rel="noopener" class="text-sm px-3.5 py-1.5 rounded-full border border-[var(--color-border)] text-[var(--color-fg-muted)] hover:border-[var(--color-coral)] hover:text-[var(--color-coral)] transition">Instagram</a>
        </div>
      </div>
    </div>

    <div class="pt-8 border-t border-[var(--color-border)] flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <p class="text-xs text-[var(--color-fg-muted)]">
        © {currentYear} Ethereum Lima. Construyendo el ecosistema Web3 en Perú.
      </p>
      <p class="text-xs text-[var(--color-fg-muted)] font-mono">
        Hecho con <span class="gradient-llama">Ξ</span> en Lima
      </p>
    </div>
  </div>
</footer>
