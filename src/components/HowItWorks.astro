---
import Section from "./ui/Section.astro";
import Icon from "./ui/Icon.astro";
import Eyebrow from "./ui/Eyebrow.astro";
import type { IconName } from "@/data/icons";
import { getContent, isLocale, DEFAULT_LOCALE } from "@/i18n";
import { accentPalette } from "@/data/tokens";

const lang = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const t = getContent(lang);
const s = t.sections.howItWorks;
---

<Section id="how-it-works" variant="muted">
  <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-start">

    <div class="lg:col-span-4">
      <Eyebrow>{s.eyebrow}</Eyebrow>
      <h2 class="font-display text-3xl md:text-4xl mt-4 mb-8 leading-[1.1]">
        {s.headingLine1}<br />
        {s.headingLine2Pre}<span class="gradient-llama">{s.headingLine2Highlight}</span>{s.headingLine2Post}
      </h2>

      <div class="space-y-5 mt-10">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-2xl bg-coral/15 border border-coral/30 flex items-center justify-center flex-shrink-0">
            <Icon name="clock" class="w-5 h-5 text-coral" />
          </div>
          <div>
            <p class="text-xs text-fg-muted uppercase tracking-wider">{s.durationLabel}</p>
            <p class="font-semibold text-lg">{t.cohort.weeks} {t.cohort.weeksLabel}</p>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-2xl bg-cyan/15 border border-cyan/30 flex items-center justify-center flex-shrink-0">
            <Icon name="signal" class="w-5 h-5 text-cyan" />
          </div>
          <div>
            <p class="text-xs text-fg-muted uppercase tracking-wider">{s.formatLabel}</p>
            <p class="font-semibold text-lg">{t.cohort.format}</p>
          </div>
        </div>
      </div>
    </div>

    <div class="lg:col-span-8 grid sm:grid-cols-2 gap-4 reveal-stagger">
      {
        t.features.map((feature, i) => (
          <div
            class={`card p-6 ${i === t.features.length - 1 ? "sm:col-span-2" : ""}`}
          >
            <div
              class="w-11 h-11 rounded-xl flex items-center justify-center mb-4 border"
              style={`background-color: ${accentPalette[i % accentPalette.length]}22; border-color: ${accentPalette[i % accentPalette.length]}55; color: ${accentPalette[i % accentPalette.length]};`}
            >
              <Icon
                name={feature.icon as IconName}
                class="w-5 h-5"
                strokeWidth={1.8}
              />
            </div>
            <h3 class="font-display text-lg font-bold mb-1.5">{feature.title}</h3>
            <p class="text-sm text-fg-muted leading-relaxed">{feature.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</Section>
