---
import Section from "./ui/Section.astro";
import { features, cohort } from "@/data/content";

const iconPaths: Record<string, string> = {
  video:
    "M15 10l4.553-2.276A1 1 0 0 1 21 8.618v6.764a1 1 0 0 1-1.447.894L15 14M5 18h8a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2z",
  code: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4",
  rocket:
    "M5 13l-1.5 6L9 17.5M19 11l1.5-6L15 6.5M14.5 14.5L9.5 9.5m9-1.5a4 4 0 1 0-5.5-5.5L4 12l8 8 8.5-8.5z",
  chat:
    "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.86 9.86 0 0 1-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z",
  book: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253",
};

const accents = ["#e64a30", "#f18a2e", "#3dbed5", "#2ca89f", "#c7f73a"];
---

<Section id="como-funciona" variant="muted">
  <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-start">

    <div class="lg:col-span-4">
      <span class="text-xs uppercase tracking-[0.25em] font-mono font-semibold text-[var(--color-bootcamp-lime)]">
        Cómo funciona
      </span>
      <h2 class="font-display text-3xl md:text-4xl mt-4 mb-8 leading-[1.1]">
        Aprendizaje en vivo,<br />
        ejecución <span class="gradient-llama">continua</span>.
      </h2>

      <div class="space-y-5 mt-10">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-2xl bg-[var(--color-coral)]/15 border border-[var(--color-coral)]/30 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-[var(--color-coral)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0z" />
            </svg>
          </div>
          <div>
            <p class="text-xs text-[var(--color-fg-muted)] uppercase tracking-wider">Duración</p>
            <p class="font-semibold text-lg">{cohort.weeks} semanas</p>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-2xl bg-[var(--color-cyan)]/15 border border-[var(--color-cyan)]/30 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-[var(--color-cyan)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 0 1 2 2v1a2 2 0 0 0 2 2 2 2 0 0 1 2 2v2.945M8 3.935V5.5A2.5 2.5 0 0 0 10.5 8h.5a2 2 0 0 1 2 2 2 2 0 0 0 4 0 2 2 0 0 1 2-2h1.064M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z" />
            </svg>
          </div>
          <div>
            <p class="text-xs text-[var(--color-fg-muted)] uppercase tracking-wider">Formato</p>
            <p class="font-semibold text-lg">{cohort.format}</p>
          </div>
        </div>
      </div>
    </div>

    <div class="lg:col-span-8 grid sm:grid-cols-2 gap-4 reveal-stagger">
      {
        features.map((feature, i) => (
          <div
            class={`card p-6 ${i === features.length - 1 ? "sm:col-span-2" : ""}`}
            style={`--feature-color: ${accents[i % accents.length]}`}
          >
            <div
              class="w-11 h-11 rounded-xl flex items-center justify-center mb-4 border"
              style={`background-color: ${accents[i % accents.length]}22; border-color: ${accents[i % accents.length]}55;`}
            >
              <svg
                class="w-5 h-5"
                style={`color: ${accents[i % accents.length]}`}
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[feature.icon]} />
              </svg>
            </div>
            <h3 class="font-display text-lg font-bold mb-1.5">{feature.title}</h3>
            <p class="text-sm text-[var(--color-fg-muted)] leading-relaxed">{feature.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</Section>
