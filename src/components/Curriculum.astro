---
import Section from "./ui/Section.astro";
import Eyebrow from "./ui/Eyebrow.astro";
import Icon from "./ui/Icon.astro";
import { getContent, isLocale, DEFAULT_LOCALE } from "@/i18n";

const lang = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const t = getContent(lang);
const s = t.sections.curriculum;

// Contrast text color for the module chip by accent.from.
// Coral & bootcamp-blue are dark → cream text. Orange & cyan are bright → ink text.
const NODE_TEXT_ON: Record<string, string> = {
  "#e64a30": "#fff8ee",
  "#f18a2e": "#0b0717",
  "#3dbed5": "#0b0717",
  "#3d43e0": "#fff8ee",
};

const speakerInitials = (name: string) =>
  name
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => part[0]?.toUpperCase() ?? "")
    .join("");

// Flatten every topic across all modules into a single chronological schedule.
type Person = { name: string; handle: string | null; role: string | null; photo: string };
type Sess = {
  moduleNumber: string;
  moduleTitle: string;
  accent: string;
  title: string;
  description: string;
  speaker: Person | null;
  coSpeaker: Person | null;
  day: string;
  date: string;
  time: string;
};

const sessions: Sess[] = t.modules.flatMap((mod) =>
  mod.topics.map((topic) => ({
    moduleNumber: mod.number,
    moduleTitle: mod.title,
    accent: mod.accent.from,
    title: topic.title,
    description: topic.description,
    speaker: topic.speaker ?? null,
    coSpeaker: "coSpeaker" in topic ? (topic.coSpeaker as Person) : null,
    day: topic.schedule.day,
    date: topic.schedule.date,
    time: topic.schedule.time,
  })),
);

// Sort by date (dd/mm, 2026) then by start time.
const sortKey = (x: Sess) => {
  const [d, m] = x.date.split("/").map(Number);
  const [h, min] = x.time.split("–")[0].split(":").map(Number);
  return m * 1e6 + d * 1e4 + h * 100 + min;
};
sessions.sort((a, b) => sortKey(a) - sortKey(b));
---

<Section id="curriculum" variant="muted">
  <Eyebrow>{s.eyebrow}</Eyebrow>
  <h2 class="font-display text-3xl md:text-5xl mt-4 mb-3 leading-[1.1]">
    {s.headingLine1}<br />
    {s.headingLine2Pre}<span class="gradient-llama">{s.headingLine2Highlight}</span>{s.headingLine2Post}
  </h2>
  <p class="text-lg text-fg-muted max-w-2xl mb-10">
    {s.body}
  </p>

  <div class="curr-sched card overflow-hidden p-0 reveal">
    {/* Header row — desktop only */}
    <div
      class="curr-head font-mono text-[11px] font-semibold uppercase tracking-[0.18em] text-fg-muted"
    >
      <span style="grid-area: mod;">{s.modulePrefix}</span>
      <span style="grid-area: date;">{s.dateLabel}</span>
      <span style="grid-area: time;">{s.timeLabel}</span>
      <span style="grid-area: topic;">{s.topicsLabel}</span>
      <span style="grid-area: speaker;">{s.speakersLabel}</span>
    </div>

    {
      sessions.map((row, i) => {
        const accent = row.accent;
        const chipFg = NODE_TEXT_ON[accent] ?? "#fff8ee";
        const newDay = i === 0 || sessions[i - 1].date !== row.date;
        const speakerName = row.speaker
          ? row.coSpeaker
            ? `${row.speaker.name} · ${row.coSpeaker.name}`
            : row.speaker.name
          : s.speakerTbaLabel;
        return (
          <div
            class={`curr-row ${newDay ? "curr-row-newday" : ""}`}
            style={`--curr-accent: ${accent};`}
          >
            {/* Module chip */}
            <div class="curr-cell-mod" style="grid-area: mod;">
              <span
                class="inline-grid place-items-center w-9 h-9 rounded-lg font-display font-extrabold text-sm leading-none"
                style={`background-color: ${accent}; color: ${chipFg};`}
                title={`${s.modulePrefix} ${row.moduleNumber} · ${row.moduleTitle}`}
              >
                {row.moduleNumber}
              </span>
            </div>

            {/* Date + day */}
            <div class="curr-cell-date" style="grid-area: date;">
              <span class="font-semibold text-[14px] leading-tight">{row.date}</span>
              <span class="text-[12px] text-fg-muted leading-tight"> {row.day}</span>
            </div>

            {/* Time */}
            <div style="grid-area: time;">
              <span
                class="font-mono text-[12px] font-semibold px-2 py-1 rounded-md whitespace-nowrap"
                style={`background-color: ${accent}1a; color: ${accent};`}
              >
                {row.time}
              </span>
            </div>

            {/* Topic */}
            <div style="grid-area: topic;" class="min-w-0">
              <span class="font-semibold text-[15px] leading-snug block">{row.title}</span>
              <span class="hidden md:block text-[12.5px] text-fg-muted leading-relaxed mt-0.5 max-w-[42ch]">
                {row.description}
              </span>
            </div>

            {/* Speaker */}
            <div style="grid-area: speaker;" class="curr-cell-speaker">
              {row.speaker && (
                <span
                  class="curr-avatar relative grid w-9 h-9 rounded-full place-items-center overflow-hidden flex-shrink-0 font-display font-bold text-[12px] leading-none"
                  style={`background-color: ${accent}; color: ${chipFg};`}
                  aria-hidden="true"
                >
                  <span>{speakerInitials(row.speaker.name)}</span>
                  <img
                    src={row.speaker.photo}
                    alt=""
                    loading="lazy"
                    decoding="async"
                    class="absolute inset-0 w-full h-full object-cover"
                    onerror="this.style.display='none'"
                  />
                </span>
              )}
              <span
                class={`text-[13.5px] leading-tight ${row.speaker ? "font-semibold" : "font-medium text-fg-muted italic"}`}
              >
                {speakerName}
              </span>
            </div>
          </div>
        );
      })
    }
  </div>

  {/* === Outcome card === */}
  <article class="card curr-finish relative overflow-hidden p-6 sm:p-7 lg:p-8 mt-6">
    <div class="relative flex items-start gap-4">
      <div
        class="curr-node w-12 h-12 rounded-2xl grid place-items-center bg-bootcamp-lime text-ink flex-shrink-0"
      >
        <Icon name="check" class="w-5 h-5" strokeWidth={3} />
      </div>
      <div>
        <span class="font-mono text-xs font-semibold uppercase tracking-[0.25em] text-bootcamp-blue">
          {s.outcomeEyebrow}
        </span>
        <h3 class="font-display text-2xl lg:text-[28px] font-bold leading-tight mt-2 mb-2">
          {s.outcomeTitle}
        </h3>
        <p class="text-fg-muted leading-relaxed max-w-[60ch]">{s.outcomeBody}</p>
      </div>
    </div>
  </article>
</Section>

<style>
  /* === Column template shared by header + rows on desktop === */
  .curr-head,
  .curr-row {
    --curr-cols: auto auto auto minmax(0, 1fr) minmax(160px, auto);
  }

  /* ---------- MOBILE (default): stacked cards ---------- */
  .curr-sched {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 0.6rem;
    background: transparent;
    border: none;
  }
  .curr-head {
    display: none;
  }
  .curr-row {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-areas:
      "mod    date"
      "time   time"
      "topic  topic"
      "speaker speaker";
    align-items: center;
    gap: 0.55rem 0.75rem;
    padding: 1rem 1.1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.9rem;
    background: var(--color-surface);
    border-left: 3px solid var(--curr-accent);
  }
  .curr-cell-date {
    justify-self: end;
    text-align: right;
  }
  .curr-cell-speaker {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding-top: 0.55rem;
    border-top: 1px solid color-mix(in srgb, var(--color-border) 70%, transparent);
  }

  /* ---------- DESKTOP (sm+): table rows ---------- */
  @media (min-width: 640px) {
    .curr-sched {
      display: block;
      gap: 0;
      padding: 0;
      border: 1px solid var(--color-border);
      border-radius: 1rem;
      background: var(--color-surface);
    }
    .curr-head {
      display: grid;
      grid-template-columns: var(--curr-cols);
      grid-template-areas: "mod date time topic speaker";
      align-items: center;
      gap: 0 0.75rem;
      padding: 0.9rem 1.5rem;
      border-bottom: 1px solid var(--color-border);
      background: var(--color-surface-2);
    }
    .curr-row {
      grid-template-columns: var(--curr-cols);
      grid-template-areas: "mod date time topic speaker";
      align-items: center;
      gap: 0 0.75rem;
      padding: 0.85rem 1.5rem;
      border: none;
      border-radius: 0;
      border-bottom: 1px solid color-mix(in srgb, var(--color-border) 60%, transparent);
      background: transparent;
      transition: background-color 0.18s ease;
    }
    .curr-row:last-child {
      border-bottom: none;
    }
    /* Thicker divider when the calendar day changes → groups sessions */
    .curr-row-newday {
      border-top: 2px solid var(--color-border);
    }
    .curr-row:hover {
      background: color-mix(in srgb, var(--curr-accent) 7%, transparent);
    }
    .curr-cell-date {
      justify-self: start;
      text-align: left;
    }
    .curr-cell-speaker {
      padding-top: 0;
      border-top: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .curr-row {
      transition: none;
    }
  }

  /* Subtle tint on the outcome card to nudge it apart from the table */
  .curr-finish {
    background:
      var(--card-overlay, transparent),
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--color-bootcamp-blue) 6%, var(--color-surface)),
        var(--color-surface) 70%
      );
  }
</style>
