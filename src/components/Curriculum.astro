---
import Section from "./ui/Section.astro";
import Button from "./ui/Button.astro";
import Icon from "./ui/Icon.astro";
import Eyebrow from "./ui/Eyebrow.astro";
import CardGlow from "./ui/CardGlow.astro";
import { getContent, isLocale, DEFAULT_LOCALE } from "@/i18n";

const lang = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const t = getContent(lang);
const s = t.sections.curriculum;
---

<Section id="curriculum" variant="muted">
  <Eyebrow>{s.eyebrow}</Eyebrow>
  <h2 class="font-display text-3xl md:text-5xl mt-4 mb-3 leading-[1.1]">
    {s.headingLine1}<br />
    {s.headingLine2Pre}<span class="gradient-llama">{s.headingLine2Highlight}</span>{s.headingLine2Post}
  </h2>
  <p class="text-lg text-fg-muted max-w-2xl mb-12">
    {s.body}
  </p>

  <div class="grid md:grid-cols-2 gap-5 reveal-stagger">
    {
      t.modules.map((mod) => (
        <div
          class="card p-8 group relative overflow-hidden"
          style={`--accent-from: ${mod.accent.from}; --accent-to: ${mod.accent.to};`}
        >
          <CardGlow
            color={mod.accent.from}
            class="-top-20 -right-20 w-48 h-48 opacity-15 group-hover:opacity-30 transition-opacity duration-500"
          />

          <div class="relative">
            <div class="flex items-center justify-between mb-6">
              <span
                class="font-mono text-sm font-semibold tracking-wider"
                style={`color: ${mod.accent.from};`}
              >
                {s.modulePrefix} {mod.number}
              </span>
              <span
                class="text-[10px] uppercase tracking-widest px-2.5 py-1 rounded-full border font-mono font-semibold"
                style={`color: ${mod.accent.to}; border-color: ${mod.accent.to}55; background: ${mod.accent.to}11;`}
              >
                {mod.level}
              </span>
            </div>
            <h3 class="font-display text-2xl md:text-3xl font-bold mb-3">{mod.title}</h3>
            <p class="text-fg-muted leading-relaxed">{mod.description}</p>
          </div>
        </div>
      ))
    }
  </div>

  <div class="text-center mt-12">
    <Button href={t.site.programPdf} variant="ghost" size="lg" external>
      {t.ui.programPdfFull}
      <Icon name="arrow-right" class="w-4 h-4" />
    </Button>
  </div>
</Section>
