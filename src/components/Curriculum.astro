---
import Section from "./ui/Section.astro";
import Eyebrow from "./ui/Eyebrow.astro";
import CardGlow from "./ui/CardGlow.astro";
import Icon from "./ui/Icon.astro";
import { getContent, isLocale, DEFAULT_LOCALE } from "@/i18n";

const lang = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const t = getContent(lang);
const s = t.sections.curriculum;

// Contrast text color for the numbered node by accent.from.
// Coral & bootcamp-blue are dark → cream text. Orange & cyan are bright → ink text.
const NODE_TEXT_ON: Record<string, string> = {
  "#e64a30": "#fff8ee",
  "#f18a2e": "#0b0717",
  "#3dbed5": "#0b0717",
  "#3d43e0": "#fff8ee",
};

const speakerInitials = (name: string) =>
  name
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => part[0]?.toUpperCase() ?? "")
    .join("");
---

<Section id="curriculum" variant="muted">
  <Eyebrow>{s.eyebrow}</Eyebrow>
  <h2 class="font-display text-3xl md:text-5xl mt-4 mb-3 leading-[1.1]">
    {s.headingLine1}<br />
    {s.headingLine2Pre}<span class="gradient-llama">{s.headingLine2Highlight}</span>{s.headingLine2Post}
  </h2>
  <p class="text-lg text-fg-muted max-w-2xl mb-12">
    {s.body}
  </p>

  <div
    class="curr-timeline relative grid grid-cols-[56px_1fr] sm:grid-cols-[88px_1fr] gap-x-3.5 sm:gap-x-6 gap-y-7 reveal-stagger"
  >
    {
      t.modules.map((mod) => {
        const accent = mod.accent.from;
        const nodeFg = NODE_TEXT_ON[accent] ?? "#fff8ee";
        const uniqueSpeakers = mod.topics.reduce<
          { name: string; handle: string | null; role: string | null; photo: string }[]
        >((acc, topic) => {
          if (topic.speaker && !acc.find((s) => s.name === topic.speaker!.name)) {
            acc.push(topic.speaker);
          }
          const co = "coSpeaker" in topic ? topic.coSpeaker : null;
          if (co && !acc.find((s) => s.name === co.name)) {
            acc.push(co);
          }
          return acc;
        }, []);
        return (
          <Fragment>
            <div class="curr-rail relative flex justify-center pt-5 sm:pt-[26px] z-10">
              <div
                class="curr-node w-12 h-12 sm:w-16 sm:h-16 rounded-2xl grid place-items-center font-display font-extrabold text-xl sm:text-2xl leading-none"
                style={`background-color: ${accent}; color: ${nodeFg};`}
              >
                {mod.number}
              </div>
            </div>

            <article class="card relative overflow-hidden p-6 sm:p-7 lg:p-8">
              <CardGlow color={accent} />
              <div class="relative">
                <div class="flex items-center justify-between gap-4 mb-2.5">
                  <span
                    class="font-mono text-xs font-semibold uppercase tracking-[0.25em]"
                    style={`color: ${accent};`}
                  >
                    {s.modulePrefix} {mod.number}
                  </span>
                  <span
                    class="font-mono text-[10px] font-semibold uppercase tracking-[0.18em] px-2.5 py-1 rounded-full border text-fg whitespace-nowrap"
                    style={`background-color: ${accent}26; border-color: ${accent}66;`}
                  >
                    {mod.level}
                  </span>
                </div>

                <h3 class="font-display text-2xl lg:text-[28px] font-bold leading-tight mb-2">
                  {mod.title}
                </h3>
                <p class="text-fg-muted leading-relaxed mb-6 max-w-[56ch]">
                  {mod.description}
                </p>

                {uniqueSpeakers.length > 0 && (
                  <>
                    <div
                      class="font-mono text-[11px] font-semibold uppercase tracking-[0.2em] mb-3"
                      style={`color: ${accent};`}
                    >
                      {s.speakersLabel.toUpperCase()}{" "}
                      <span class="text-fg-muted">· {uniqueSpeakers.length}</span>
                    </div>
                    <div class="flex flex-wrap gap-2.5 mb-6">
                      {uniqueSpeakers.map((sp) => (
                        <div
                          class="curr-speaker flex items-center gap-3 rounded-xl border border-border bg-surface-2 py-2 pl-2 pr-4"
                          style={`--curr-accent: ${accent};`}
                        >
                          <span
                            class="curr-avatar relative w-12 h-12 sm:w-14 sm:h-14 rounded-full grid place-items-center overflow-hidden flex-shrink-0 font-display font-bold text-base leading-none"
                            style={`background-color: ${accent}; color: ${nodeFg};`}
                            aria-hidden="true"
                          >
                            <span class="curr-avatar-initials">{speakerInitials(sp.name)}</span>
                            <img
                              src={sp.photo}
                              alt=""
                              loading="lazy"
                              decoding="async"
                              class="curr-avatar-img absolute inset-0 w-full h-full object-cover"
                              onerror="this.style.display='none'"
                            />
                          </span>
                          <div class="min-w-0">
                            <p class="font-semibold text-[14px] leading-tight">{sp.name}</p>
                            {sp.handle && (
                              <p
                                class="font-mono text-[11px] leading-tight mt-0.5"
                                style={`color: ${accent};`}
                              >
                                @{sp.handle}
                              </p>
                            )}
                            {sp.role && (
                              <p class="text-[12px] text-fg-muted leading-tight mt-0.5">
                                {sp.role}
                              </p>
                            )}
                          </div>
                        </div>
                      ))}
                    </div>
                  </>
                )}

                <div
                  class="font-mono text-[11px] font-semibold uppercase tracking-[0.2em] mb-3"
                  style={`color: ${accent};`}
                >
                  {s.topicsLabel.toUpperCase()}{" "}
                  <span class="text-fg-muted">· {mod.topics.length}</span>
                </div>

                <ul class="grid sm:grid-cols-2 gap-2.5 list-none p-0 m-0">
                  {mod.topics.map((topic, ti) => (
                    <li
                      class="curr-topic rounded-xl border border-border bg-surface-2 p-3.5 flex flex-col"
                      style={`--curr-accent: ${accent};`}
                    >
                      <div
                        class="font-mono text-[10px] font-semibold uppercase tracking-[0.2em] mb-1"
                        style={`color: ${accent};`}
                      >
                        {s.topicPrefix} {String(ti + 1).padStart(2, "0")}
                      </div>
                      <p class="font-semibold text-[14.5px] leading-snug mb-0.5">{topic.title}</p>
                      <p class="text-[13px] text-fg-muted leading-relaxed mb-3">{topic.description}</p>

                      <div class="curr-meta mt-auto pt-3 border-t border-border flex items-center gap-2 flex-wrap justify-between">
                        <span class={`text-[12.5px] leading-tight truncate ${topic.speaker ? "font-semibold" : "font-medium text-fg-muted italic"}`}>
                          {topic.speaker
                            ? ("coSpeaker" in topic && topic.coSpeaker
                                ? `${topic.speaker.name} · ${topic.coSpeaker.name}`
                                : topic.speaker.name)
                            : s.speakerTbaLabel}
                        </span>
                        <span
                          class="font-mono text-[10px] font-semibold uppercase tracking-[0.18em] px-2 py-1 rounded-md whitespace-nowrap"
                          style={`background-color: ${accent}1a; color: ${accent};`}
                        >
                          {topic.schedule.day} {topic.schedule.date} · {topic.schedule.time}
                        </span>
                      </div>
                    </li>
                  ))}
                </ul>
              </div>
            </article>
          </Fragment>
        );
      })
    }

    {/* === Finish row: el deploy === */}
    <div class="curr-rail relative flex justify-center pt-5 sm:pt-[26px] z-10">
      <div
        class="curr-node w-12 h-12 sm:w-16 sm:h-16 rounded-2xl grid place-items-center bg-bootcamp-lime text-ink"
      >
        <Icon name="check" class="w-5 h-5 sm:w-6 sm:h-6" strokeWidth={3} />
      </div>
    </div>
    <article class="card curr-finish relative overflow-hidden p-6 sm:p-7 lg:p-8">
      <div class="relative">
        <span
          class="font-mono text-xs font-semibold uppercase tracking-[0.25em] text-bootcamp-blue"
        >
          {s.outcomeEyebrow}
        </span>
        <h3 class="font-display text-2xl lg:text-[28px] font-bold leading-tight mt-2.5 mb-2">
          {s.outcomeTitle}
        </h3>
        <p class="text-fg-muted leading-relaxed max-w-[60ch]">{s.outcomeBody}</p>
      </div>
    </article>
  </div>
</Section>

<style>
  /* Continuous brand-gradient connector running behind the nodes */
  .curr-timeline::before {
    content: "";
    position: absolute;
    top: 44px;
    bottom: 44px;
    left: 28px;
    width: 2px;
    transform: translateX(-1px);
    background: linear-gradient(
      to bottom,
      var(--color-coral),
      var(--color-orange) 22%,
      var(--color-cyan) 50%,
      var(--color-teal) 65%,
      var(--color-bootcamp-blue) 85%,
      var(--color-bootcamp-lime) 100%
    );
    opacity: 0.5;
    pointer-events: none;
    z-index: 0;
  }
  @media (min-width: 640px) {
    .curr-timeline::before {
      top: 58px;
      bottom: 58px;
      left: 44px;
    }
  }

  /* Ring matches section bg so the line appears to pass behind the node */
  .curr-node {
    box-shadow: 0 0 0 6px var(--color-surface-2);
    transition: transform 0.25s ease;
  }
  .curr-node:hover {
    transform: scale(1.08) rotate(-3deg);
  }

  /* Topic cards: accent border + lift on hover */
  .curr-topic {
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .curr-topic:hover {
    border-color: var(--curr-accent);
    transform: translateY(-1px);
  }

  /* Subtle tint on the outcome card to nudge it apart from modules */
  .curr-finish {
    background:
      var(--card-overlay, transparent),
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--color-bootcamp-blue) 6%, var(--color-surface)),
        var(--color-surface) 70%
      );
  }

  @media (max-width: 1024px) {
    .curr-node:hover,
    .curr-topic:hover,
    .card:hover {
      transform: none !important;
    }
    .curr-rail,
    .card {
      transition: none !important;
    }
    /* Hide decorative glows on mobile for better performance */
    :global(.absolute.rounded-full.blur-3xl) {
      display: none !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .curr-node,
    .curr-topic {
      transition: none;
    }
    .curr-node:hover {
      transform: none;
    }
  }
</style>
