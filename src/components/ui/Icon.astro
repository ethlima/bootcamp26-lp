---
import { icons, type IconName } from "@/data/icons";

interface Props {
  name: IconName;
  class?: string;
  strokeWidth?: number;
}

const {
  name,
  class: className = "w-5 h-5",
  strokeWidth = 2,
} = Astro.props;
---

<svg
  class={className}
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  viewBox="0 0 24 24"
  aria-hidden="true"
>
  <path stroke-linecap="round" stroke-linejoin="round" d={icons[name]} />
</svg>
