---
interface Props {
  href: string;
  variant?: "primary" | "secondary" | "ghost";
  size?: "md" | "lg";
  external?: boolean;
  class?: string;
}

const {
  href,
  variant = "primary",
  size = "md",
  external = false,
  class: className = "",
} = Astro.props;

const base =
  "inline-flex items-center justify-center gap-2 rounded-full font-semibold transition-all duration-200 whitespace-nowrap";

const variants = {
  primary:
    "bg-[var(--color-bootcamp-lime)] text-[var(--color-ink)] hover:bg-white hover:scale-[1.02] shadow-[0_0_40px_-10px_rgba(199,247,58,0.6)]",
  secondary:
    "bg-[var(--color-bootcamp-blue)] text-white hover:bg-[var(--color-bootcamp-purple)] shadow-[0_0_40px_-12px_rgba(61,67,224,0.7)]",
  ghost:
    "border border-[var(--color-border-strong)] text-[var(--color-fg)] hover:border-white hover:bg-white/5",
};

const sizes = {
  md: "px-6 py-3 text-sm",
  lg: "px-8 py-4 text-base",
};

const targetProps = external ? { target: "_blank", rel: "noopener noreferrer" } : {};
---

<a
  href={href}
  class={`${base} ${variants[variant]} ${sizes[size]} ${className}`}
  {...targetProps}
>
  <slot />
</a>
