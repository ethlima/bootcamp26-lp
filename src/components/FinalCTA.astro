---
import Button from "./ui/Button.astro";
import { site, cohort } from "@/data/content";
---

<section class="relative py-24 md:py-32 px-6 border-t border-border overflow-hidden glow-hero dotted-bg">
  <div class="max-w-4xl mx-auto text-center relative reveal">

    <!-- Llama decorativa de fondo -->
    <div class="absolute -top-10 left-1/2 -translate-x-1/2 w-72 h-72 opacity-10 blur-2xl pointer-events-none"
      style="background: radial-gradient(circle, #c7f73a, transparent 60%);">
    </div>

    <h2 class="font-display text-4xl md:text-6xl lg:text-7xl mb-6 leading-[1.05]">
      ¿Listo para <span class="gradient-llama">construir</span>?
    </h2>
    <p class="text-lg md:text-xl text-fg-muted mb-3">
      Únete al bootcamp y comienza a crear en Web3.
    </p>
    <p class="text-sm text-fg-muted mb-10">
      <strong class="text-white">Próxima cohorte:</strong> {cohort.startDate}
    </p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <Button href={site.applyUrl} external variant="primary" size="lg">
        Aplicar ahora
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </Button>
      <Button href={`mailto:${site.contactEmail}`} variant="ghost" size="lg">
        Tengo una pregunta
      </Button>
    </div>
  </div>
</section>
