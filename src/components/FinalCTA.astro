---
import Button from "./ui/Button.astro";
import Icon from "./ui/Icon.astro";
import { getContent, isLocale, DEFAULT_LOCALE } from "@/i18n";
import { brandColors } from "@/data/tokens";

const lang = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const t = getContent(lang);
const s = t.sections.finalCta;
---

<section class="relative py-24 md:py-32 px-6 border-t border-border overflow-hidden glow-hero dotted-bg">
  <div class="max-w-4xl mx-auto text-center relative reveal">

    <!-- Spotlight decorativo de fondo -->
    <div class="absolute -top-10 left-1/2 -translate-x-1/2 w-72 h-72 opacity-10 blur-2xl pointer-events-none"
      style={`background: radial-gradient(circle, ${brandColors.bootcampLime}, transparent 60%);`}>
    </div>

    <h2 class="font-display text-4xl md:text-6xl lg:text-7xl mb-6 leading-[1.05]">
      {s.headingPre}<span class="gradient-llama">{s.headingHighlight}</span>{s.headingPost}
    </h2>
    <p class="text-lg md:text-xl text-fg-muted mb-3">
      {s.body}
    </p>
    <p class="text-sm text-fg-muted mb-10">
      <strong class="text-fg">{s.nextCohortLabel}</strong> {t.cohort.startDate}
    </p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <Button href={t.site.applyUrl} external variant="primary" size="lg">
        {t.ui.applyNow}
        <Icon name="arrow-right" class="w-4 h-4" strokeWidth={2.5} />
      </Button>
      <Button href={`mailto:${t.site.contactEmail}`} variant="ghost" size="lg">
        {t.ui.iHaveAQuestion}
      </Button>
    </div>
  </div>
</section>
