---
import { brandColors } from "@/data/tokens";

const items = [
  { label: "Solidity", color: brandColors.coral },
  { label: "Rust", color: brandColors.orange },
  { label: "Arbitrum Stylus", color: brandColors.cyan },
  { label: "Smart Contracts", color: brandColors.teal },
  { label: "Layer 2", color: brandColors.bootcampLime },
  { label: "dApps", color: brandColors.bootcampPurple },
  { label: "Foundry", color: brandColors.coral },
  { label: "Hardhat", color: brandColors.cyan },
  { label: "Ethers.js", color: brandColors.orange },
  { label: "Web3", color: brandColors.teal },
  { label: "DeFi", color: brandColors.bootcampLime },
  { label: "EVM", color: brandColors.bootcampPurple },
];

const sep = "✦";
---

<div class="marquee py-12 border-y border-border bg-surface-2">
  <div class="marquee-track">
    {
      [...items, ...items].map((item) => (
        <span class="flex items-center gap-6 px-6">
          <span
            class="font-display text-2xl md:text-3xl font-semibold whitespace-nowrap"
            style={`color: ${item.color}`}
          >
            {item.label}
          </span>
          <span
            class="text-sm opacity-30"
            style={`color: ${item.color}`}
            aria-hidden="true"
          >
            {sep}
          </span>
        </span>
      ))
    }
  </div>
</div>
