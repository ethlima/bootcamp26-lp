---
import "@/styles/global.css";
import { getContent, isLocale, LOCALES, DEFAULT_LOCALE } from "@/i18n";
import { getRelativeLocaleUrl } from "astro:i18n";

interface Props {
  title?: string;
  description?: string;
}

const lang = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const t = getContent(lang);

const { title = t.site.name, description = t.site.description } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? t.site.url).toString();
const ogImage = new URL("/assets/llama-bootcamp.jpg", Astro.site ?? t.site.url).toString();

const hreflangMap: Record<string, string> = { es: "es-PE", en: "en-US" };
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0b0717" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fff8ee" media="(prefers-color-scheme: light)" />
    <meta name="robots" content="index, follow" />

    <script is:inline>
      // FOUC prevention: apply stored theme before first paint
      (function () {
        try {
          var stored = localStorage.getItem("eth-lima-theme");
          if (stored === "dark" || stored === "light") {
            document.documentElement.setAttribute("data-theme", stored);
          }
        } catch (e) {
          /* localStorage unavailable */
        }
      })();
    </script>
    <link rel="icon" type="image/png" href="/assets/favicon.png" />
    <link rel="canonical" href={canonicalURL} />

    {
      LOCALES.map((loc) => (
        <link
          rel="alternate"
          hreflang={hreflangMap[loc]}
          href={new URL(getRelativeLocaleUrl(loc, ""), Astro.site ?? t.site.url).toString()}
        />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(getRelativeLocaleUrl(DEFAULT_LOCALE, ""), Astro.site ?? t.site.url).toString()}
    />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Ethereum Lima" />
    <meta property="og:locale" content={t.ogLocale} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />
  </head>
  <body>
    <slot />

    <script>
      // Reveal on scroll — vanilla IntersectionObserver, no deps
      if ("IntersectionObserver" in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.15, rootMargin: "0px 0px -60px 0px" }
        );
        const targets = document.querySelectorAll(".reveal, .reveal-stagger");
        for (const el of targets) io.observe(el);
      } else {
        document.querySelectorAll(".reveal, .reveal-stagger").forEach((el) => {
          el.classList.add("is-visible");
        });
      }
    </script>
  </body>
</html>
